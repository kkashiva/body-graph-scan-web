# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Neon Auth
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.region.aws.neon.tech/dbname/auth
NEON_AUTH_COOKIE_SECRET=generate-with-openssl-rand-base64-32

# Vercel Blob (scoped read/write token — create in Vercel Storage dashboard)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# VLM Provider — 'gemini' (default) or 'qwen'
VLM_PROVIDER=qwen
VLM_MODEL=qwen3.6-plus

# VLM_PROVIDER=gemini
# VLM_MODEL=gemini-3.1-flash-lite

# Google Gemini (required when VLM_PROVIDER=gemini)
GOOGLE_API_KEY=

# Alibaba Cloud Model Studio (DashScope) — required when VLM_PROVIDER=qwen
# Generate at https://bailian.console.alibabacloud.com/ (international: Singapore)
DASHSCOPE_API_KEY=